NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# WhatsApp (Z-API) — opcional
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_ENABLED=0

# Segredo para proteção dos endpoints cron
CRON_SECRET=

# Schema script (apply-schema.mjs) — necessário apenas para setup inicial do banco
DB_HOST=db.seuprojeto.supabase.co
DB_PASSWORD=

# Backup script (scripts/backup.mjs) — Service Role Key do Supabase Dashboard
# Acesse: Supabase Dashboard > Settings > API > project service_role key
# Essa chave bypassa RLS — mantenha segura, nunca exposta no client
SUPABASE_SERVICE_ROLE_KEY=
